---------------------------------------------------------
--- [[ TAB 1: 🥚 AUTO-HATCH & TRACKER ]] ---
---------------------------------------------------------
local HatchTab = Window:CreateTab("🥚 Auto-Hatch", 4483362458)

local allEggs = {"Intermission"}
local selectedEgg = "Intermission" 
local customEggOverride = ""

HatchTab:CreateDropdown({
    Name = "Select Egg",
    Options = allEggs,
    CurrentOption = {"Intermission"},
    MultipleOptions = false,
    Flag = "EggDropdownConfig", 
    Callback = function(Option) selectedEgg = Option[1] end,
})

HatchTab:CreateInput({
    Name = "Custom Internal Name (Override)",
    PlaceholderText = "e.g. Intermission",
    RemoveTextAfterFocusLost = false,
    Flag = "CustomEggInputConfig", 
    Callback = function(Text) customEggOverride = Text end,
})

HatchTab:CreateSection("📊 Live Session Stats")
local sessionHatches = 0
local trackerLabel = HatchTab:CreateLabel("Total Eggs Hatched: 0")

HatchTab:CreateSection("🏆 Jackpot Tracker")
local gigaCount = 0
local megaCount = 0
local olympicCount = 0

local gigaLabel = HatchTab:CreateLabel("🐾 GigaSteampunkLizard: 0")
local megaLabel = HatchTab:CreateLabel("🐉 MegaClockDragon: 0")
local olympicLabel = HatchTab:CreateLabel("⏱️ OlympicClock: 0")

HatchTab:CreateToggle({
    Name = "Start Zero-Drop Synchronous Hatch",
    CurrentValue = false,
    Flag = "AutoHatchToggleConfig", 
    Callback = function(Value)
        _G.SmartHatch = Value
        if Value then
            local target = (customEggOverride ~= "") and customEggOverride or selectedEgg
            if OpenerUI then OpenerUI.Enabled = false end
            
            task.spawn(function()
                while _G.SmartHatch do
                    local hasTriple = Player:GetAttribute("TripleEggs") or false
                    local hasOcto = Player:GetAttribute("OctoEggs") or false
                    local extraHatches = Player:GetAttribute("HatchesPurchased") or 0
                    local useExtraHatches = (extraHatches > 0)
                    
                    -- The script pauses right here until the server successfully saves the egg
                    local success, pets = pcall(function()
                        return EggRF.purchaseEgg:InvokeServer(target, nil, hasTriple, false, hasOcto, useExtraHatches, nil)
                    end)
                    
                    if success and type(pets) == "table" then
                        local hatchCount = 0
                        for i, petData in pairs(pets) do
                            hatchCount = hatchCount + 1
                            local name = type(petData) == "table" and (petData.Name or petData.Key) or tostring(petData)
                            
                            if name == "GigaSteampunkLizard" then
                                gigaCount = gigaCount + 1
                                gigaLabel:Set("🐾 GigaSteampunkLizard: " .. tostring(gigaCount))
                            elseif name == "MegaClockDragon" then
                                megaCount = megaCount + 1
                                megaLabel:Set("🐉 MegaClockDragon: " .. tostring(megaCount))
                            elseif name == "OlympicClock" then
                                olympicCount = olympicCount + 1
                                olympicLabel:Set("⏱️ OlympicClock: " .. tostring(olympicCount))
                            end
                        end
                        
                        sessionHatches = sessionHatches + hatchCount
                        trackerLabel:Set("Total Eggs Hatched: " .. tostring(sessionHatches))
                    end
                    
                    -- Firing the next request the exact frame the server unlocks
                    task.wait()
                end
            end)
        else
            if OpenerUI then OpenerUI.Enabled = true end
        end
    end,
})

---------------------------------------------------------
--- [[ TAB 2: ⚔️ AUTO-FIGHT ]] ---
---------------------------------------------------------
local FightTab = Window:CreateTab("⚔️ Auto-Fight", 4483362458)

local targetBoss = ""

FightTab:CreateInput({
    Name = "Exact Boss Name",
    PlaceholderText = "e.g. WarpedRockstar",
    RemoveTextAfterFocusLost = false,
    Flag = "TargetBossInputConfig", 
    Callback = function(Text) targetBoss = Text end,
})

FightTab:CreateToggle({
    Name = "Engage Target (Auto-Kill)",
    CurrentValue = false,
    Flag = "AutoFightToggleConfig", 
    Callback = function(Value)
        _G.AutoFight = Value
        if Value then
            if targetBoss == "" then return end
            task.spawn(function()
                while _G.AutoFight do
                    pcall(function() RequestStartFight:InvokeServer(targetBoss) end)
                    for i = 1, 25 do
                        if not _G.AutoFight then break end
                        pcall(function() RequestClick:InvokeServer() end)
                        task.wait() 
                    end
                    task.wait(0.1) 
                end
            end)
        end
    end,
})

